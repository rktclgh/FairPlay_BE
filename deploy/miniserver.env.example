SPRING_PROFILES_ACTIVE=prod
APP_ENVIRONMENT=prod
APP_BASE_URL=https://fairplay.rktclgh.site
APP_FRONTEND_BASE_URL=https://fairplay.rktclgh.site
APP_CORS_ALLOWED_ORIGINS=https://fairplay.rktclgh.site
APP_POSTGRES_AUTO_INIT_CONSTRAINTS=true
UPLOAD_PATH=/app/uploads

DB_URL=jdbc:postgresql://127.0.0.1:5432/fairplay
DB_USERNAME=fairplay
DB_PASSWORD=change-me
JPA_DDL_AUTO=update
RAG_PGVECTOR_AUTO_INIT=true

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL_ENABLED=false

JWT_SECRET=change-me
HASHIDS_SALT=change-me
GEMINI_API_KEY=
LLM_PROVIDER=HERMES
HERMES_GATEWAY_BASE_URL=http://127.0.0.1:8788
HERMES_GATEWAY_API_KEY=change-me
HERMES_GATEWAY_MODEL=gpt-5.4-mini
HERMES_GATEWAY_WAIT_TIMEOUT_SECONDS=60
HERMES_GATEWAY_CONNECT_TIMEOUT_SECONDS=5
HERMES_GATEWAY_REQUEST_TIMEOUT_SECONDS=75
RAG_EMBEDDING_FALLBACK_ENABLED=false
RAG_EMBEDDING_MODEL=gemini-embedding-001
RAG_EMBEDDING_OUTPUT_DIMENSIONALITY=768
RAG_EMBEDDING_MAX_RETRIES=5
RAG_EMBEDDING_RETRY_BASE_DELAY_MS=1000
RAG_EMBEDDING_MIN_REQUEST_INTERVAL_MS=1200

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=change-me
MAIL_PASSWORD=change-me

KAKAO_CLIENT_ID=change-me
KAKAO_REDIRECT_URI=https://fairplay.rktclgh.site/auth/kakao/callback
KAKAO_CLIENT_SECRET=

AWS_S3_BUCKET_NAME=fairplay
AWS_S3_ENABLED=true
AWS_S3_ENDPOINT=http://127.0.0.1:19000
AWS_S3_PATH_STYLE_ACCESS=true
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_CLOUDFRONT_DOMAIN=https://fairplay.rktclgh.site/uploads

IAMPORT_API_KEY=change-me
IAMPORT_SECRET_KEY=change-me
IAMPORT_BASE_URL=https://api.iamport.kr

QR_TICKET_REACT_URL=https://fairplay.rktclgh.site

# Deployment-only credentials. The workflow strips these from app.env before starting containers.
DOCKERHUB_USERNAME=change-me
DOCKERHUB_TOKEN=change-me
